{
  "mcpServers": {
    "pdf-reader": {
      "tools": [
        "*"
      ],
      "command": "npx",
      "args": [
        "@sylphx/pdf-reader-mcp"
      ]
    },
    "ado-dttnl-tax-ita": {
      "tools": [
        "*"
      ],
      "type": "stdio",
      "command": "bunx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "dttnl-tax-ita",
        "-d",
        "core",
        "work",
        "work-items",
        "repositories",
        "pipelines"
      ]
    },
    "azure": {
      "tools": [
        "*"
      ],
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start"
      ]
    },
    "context7": {
      "tools": [
        "*"
      ],
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "tools": [
        "*"
      ],
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "datadog": {
      "tools": [
        "*"
      ],
      "type": "http",
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp"
    },
    "codedb": {
      "tools": [
        "*"
      ],
      "type": "stdio",
      "command": "codedb",
      "args": [
        "mcp"
      ]
    }
  }
}
