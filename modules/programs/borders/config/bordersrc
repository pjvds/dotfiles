#!/bin/bash

## JankyBorders
# https://github.com/FelixKratz/JankyBorders

# Color name → hex helpers (shared with theme switcher)
DOTFILES="${HOME}/dotfiles"
# shellcheck source=colors.sh
source "${DOTFILES}/modules/programs/borders/config/colors.sh"

# Source theme variables if available, otherwise use defaults
BORDERS_THEME_FILE="${HOME}/.local/state/theme/borders-style.sh"
if [ -f "$BORDERS_THEME_FILE" ]; then
  source "$BORDERS_THEME_FILE"
fi

# set color - use sourced variables or defaults
act_color="${BORDERS_ACTIVE_COLOR:-lightowl_blue}"
ina_color="${BORDERS_INACTIVE_COLOR:-light_gray}"
# bg_color="catp_crust"

OPTIONS=(
	hidpi=on
	width=6.0
	style=round
	#blur_radius=80.0
	# background_color="0xff$(get_hex $bg_color)"
  active_color=$(get_hex $act_color)
  inactive_color=$(get_hex $ina_color)
)

# Kill any stale borders instance before starting a new server
pkill -x borders 2>/dev/null || true

borders "${OPTIONS[@]}"
