{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "ado-dttnl-tax-ita": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@azure-devops/mcp",
        "dttnl-tax-ita",
        "-d",
        "core",
        "work",
        "work-items",
        "repositories",
        "pipelines"
      ],
      "enabled": false
    },
    "ado-ra-tes": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@azure-devops/mcp",
        "ra-tes",
        "-d",
        "core",
        "work",
        "work-items",
        "repositories",
        "pipelines"
      ],
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp",
      "enabled": false
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "webfetch": "allow",
        "external_directory": {
          "*": "ask",
          "/tmp": "allow",
          "/tmp/*": "allow",
          "/private/tmp": "allow",
          "/private/tmp/*": "allow",
          "env:$TMPDIR": "allow",
          "env:$TMPDIR/*": "allow",
          "$HOME/code": "allow"
        }
      }
    },
    "build": {
      "plan": {
        "permission": {
          "external_directory": {
            "*": "ask",
            "/tmp": "allow",
            "/tmp/*": "allow",
            "/private/tmp": "allow",
            "/private/tmp/*": "allow",
            "env:$TMPDIR": "allow",
            "env:$TMPDIR/*": "allow",
            "$HOME/code": "allow"
          }
        }
      }
    }
  }
}
